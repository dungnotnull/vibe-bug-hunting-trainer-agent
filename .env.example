# BugHunterAgent — Environment Configuration
# Copy this file to .env and adjust as needed.
# NEVER set BUGHUNTER_ENV to anything other than "sandbox" in this file.

# ─── Safety (REQUIRED) ─────────────────────────────────────────────────────
# MUST be "sandbox" or the agent refuses to start.
BUGHUNTER_ENV=sandbox

# ─── Session ───────────────────────────────────────────────────────────────
BUGHUNTER_SESSION_TIMEOUT=240
BUGHUNTER_MAX_BUGS=3
BUGHUNTER_MUTATION_RETRIES=5
BUGHUNTER_REALISM_THRESHOLD=0.7

# ─── External LLM (optional — local Qwen via Ollama is the default) ────────
# Uncomment and set to enable cloud LLM for mutation generation enhancement.
# BUGHUNTER_EXTERNAL_LLM=claude
# BUGHUNTER_EXTERNAL_MODEL=claude-sonnet-4-6
# BUGHUNTER_EXTERNAL_API_KEY=your-api-key-here

# ─── Local LLM ─────────────────────────────────────────────────────────────
BUGHUNTER_LOCAL_MODEL=qwen2.5-coder:7b
